        "mimeType": "application/json",
        "text": "{\n  \"groupName\": \"Turma de Engenharia de Software II\",\n  \"description\": \"Grupo destinado aos alunos da disciplina.\"\n}"
      },
      "headers": [
        { "name": "Content-Type", "value": "application/json" },
