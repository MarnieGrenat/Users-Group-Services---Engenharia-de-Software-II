# Copie para `.env` e ajuste. Nunca versione o `.env` real.

# Use um usuário de banco com privilégio mínimo (apenas EXECUTE nas funções sp_*).
UG_DATABASE_URL=postgresql://ug_app:troque-esta-senha@localhost:5432/ugtest

# Pool de conexões
UG_DB_POOL_MIN_SIZE=1
UG_DB_POOL_MAX_SIZE=10

# Limite de tempo por query (ms)
UG_DB_STATEMENT_TIMEOUT_MS=5000

# Bind local (backend-only). A exposição é feita pelo service mesh.
UG_HOST=127.0.0.1
UG_PORT=8000
